# =============================================================================
# FastReID Embedding Service — Variables de entorno
# Copiar a .env y completar antes de iniciar el servicio
# =============================================================================

# Entorno: development | production
APP_ENV=production

# API Key interna — generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=CAMBIAR_POR_TOKEN_SEGURO

# Logging
LOG_LEVEL=INFO

# Rutas de pesos
MODEL_PATH_PERSON=weights/person_model.pth
MODEL_PATH_VEHICLE=weights/vehicle_model.pth

# Rutas de configs FastReID
FASTREID_CONFIG_PERSON=configs/bagtricks_R50_person.yml
FASTREID_CONFIG_VEHICLE=configs/bagtricks_R50_vehicle.yml

# Nombres de modelo en respuesta JSON
MODEL_NAME_PERSON=fastreid_person
MODEL_NAME_VEHICLE=fastreid_vehicle

# Dimensión de embedding (ResNet50 = 2048)
EMBEDDING_DIMENSION=2048

# Validación de imágenes
MAX_IMAGE_MB=5.0
MIN_IMAGE_WIDTH=32
MIN_IMAGE_HEIGHT=32

# GPU: false para CPU-only, true cuando haya CUDA disponible
ENABLE_GPU=false

# Timeout por request (segundos)
REQUEST_TIMEOUT=30

# Rate limiting
RATE_LIMIT_EMBED=60/minute
RATE_LIMIT_HEALTH=120/minute
